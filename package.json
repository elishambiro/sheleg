{
  "name": "sheleg-legal",
  "private": true,
  "version": "0.1.0",
  "productName": "Sheleg - Legal Document Compiler",
  "description": "Desktop app for compiling legal document bundles into a single PDF.",
  "author": "Sheleg Team",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "node scripts/setup-fonts.mjs",
    "dev": "vite",
    "dev:desktop": "npm run build:electron && concurrently -k -n renderer,desktop -c cyan,magenta \"npm run dev -- --host 127.0.0.1 --port 3000\" \"wait-on tcp:127.0.0.1:3000 && cross-env SHELEG_RENDERER_URL=http://127.0.0.1:3000 electron .\"",
    "build": "tsc && vite build",
    "build:renderer": "npm run build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:desktop": "npm run clean && npm run build:renderer && npm run build:electron",
    "preview": "vite preview",
    "clean": "rimraf dist dist-electron out desktop-release",
    "package": "npm run build:desktop && electron-forge package",
    "make": "npm run build:desktop && electron-forge make",
    "make:win": "npm run build:desktop && electron-forge make --platform win32",
    "make:mac": "npm run make:mac:arm64",
    "make:mac:arm64": "npm run prepare:mac-icon && npm run build:desktop && electron-forge make --platform darwin --arch arm64",
    "make:mac:x64": "npm run prepare:mac-icon && npm run build:desktop && electron-forge make --platform darwin --arch x64",
    "prepare:mac-icon": "node ./scripts/desktop/prepare-macos-icon.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "idb": "^8.0.1",
    "mammoth": "^1.8.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "postcss": "^8.5.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "wait-on": "^9.0.4"
  }
}
